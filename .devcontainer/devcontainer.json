{
    "name": "Quire Dev",
    "dockerComposeFile": "docker-compose.yml",
    "service": "dev",
    "workspaceFolder": "/workspace",
    "features": {
        "ghcr.io/devcontainers/features/go:1": {
            "version": "1.26"
        },
        "ghcr.io/devcontainers/features/node:1": {
            "version": "24"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "golang.go",
                "svelte.svelte-vscode",
                "bradlc.vscode-tailwindcss",
                "esbenp.prettier-vscode",
                "mtxr.sqltools",
                "mtxr.sqltools-driver-pg",
                "ms-azuretools.vscode-docker",
                "eamodio.gitlens"
            ],
            "settings": {
                "editor.formatOnSave": true,
                "editor.defaultFormatter": "esbenp.prettier-vscode",
                "[go]": {
                    "editor.defaultFormatter": "golang.go"
                },
                "go.toolsManagement.autoUpdate": true,
                "sqltools.connections": [
                    {
                        "name": "Quire DB",
                        "driver": "PostgreSQL",
                        "host": "db",
                        "port": 5432,
                        "database": "quire",
                        "username": "quire",
                        "password": "quire"
                    }
                ]
            }
        }
    },
    "containerEnv": {
        "NODE_OPTIONS": "--max-old-space-size=4096"
    },
    "forwardPorts": [
        5173,
        8080,
        5432
    ],
    "portsAttributes": {
        "5173": {
            "label": "SvelteKit",
            "onAutoForward": "notify"
        },
        "8080": {
            "label": "Go API",
            "onAutoForward": "notify"
        },
        "5432": {
            "label": "PostgreSQL"
        }
    },
    "remoteUser": "vscode",
    "postCreateCommand": "cd /workspace/frontend && npm install; cd /workspace/backend && go mod download && go install github.com/air-verse/air@latest"
}