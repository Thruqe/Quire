		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^25.9.3",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"@tiptap/core": "^3.26.1",
		"@tiptap/extension-highlight": "^3.26.1",
